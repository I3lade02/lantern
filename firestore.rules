rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasApprovedEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && exists(
          /databases/$(database)/documents/accessAllowlist/$(request.auth.token.email)
        );
    }

    function isAdmin() {
      return hasApprovedEmail()
        && exists(
          /databases/$(database)/documents/users/$(request.auth.uid)
        )
        && get(
          /databases/$(database)/documents/users/$(request.auth.uid)
        ).data.role == "admin";
    }

    function hasValidAvatarColor(data) {
      return data.avatarColor in [
        "amber",
        "moss",
        "wine",
        "cream"
      ];
    }

    function hasValidProfileShape(data) {
      return data.keys().hasAll([
          "id",
          "displayName",
          "email",
          "avatarColor",
          "role",
          "createdAt",
          "updatedAt"
        ])
        && data.keys().hasOnly([
          "id",
          "displayName",
          "email",
          "avatarColor",
          "role",
          "createdAt",
          "updatedAt"
        ])
        && data.id is string
        && data.displayName is string
        && data.displayName.size() >= 2
        && data.displayName.size() <= 24
        && data.email is string
        && hasValidAvatarColor(data)
        && data.role in ["admin", "member"]
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidInitialProfile(userId) {
      return hasApprovedEmail()
        && hasValidProfileShape(request.resource.data)
        && request.resource.data.id == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == "member"
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isValidOwnProfileUpdate(userId) {
  return hasApprovedEmail()
    && request.auth.uid == userId
    && hasValidProfileShape(request.resource.data)
    && request.resource.data.id == resource.data.id
    && request.resource.data.email == resource.data.email
    && request.resource.data.role == resource.data.role
    && request.resource.data.createdAt == resource.data.createdAt
    && request.resource.data.updatedAt == request.time
    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
      "displayName",
      "avatarColor",
      "updatedAt"
    ]);
}

function isValidAdminRoleUpdate(userId) {
  return isAdmin()
    && request.auth.uid != userId
    && hasValidProfileShape(request.resource.data)
    && request.resource.data.id == resource.data.id
    && request.resource.data.email == resource.data.email
    && request.resource.data.displayName == resource.data.displayName
    && request.resource.data.avatarColor == resource.data.avatarColor
    && request.resource.data.createdAt == resource.data.createdAt
    && request.resource.data.updatedAt == request.time
    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
      "role",
      "updatedAt"
    ]);
}

    function hasValidRsvpSummary(summary) {
      return summary is map
        && summary.keys().hasAll(["going", "maybe", "notGoing"])
        && summary.keys().hasOnly(["going", "maybe", "notGoing"])
        && summary.going is int
        && summary.maybe is int
        && summary.notGoing is int
        && summary.going >= 0
        && summary.maybe >= 0
        && summary.notGoing >= 0;
    }

    function hasValidSessionShape(data) {
      return data.keys().hasAll([
          "id",
          "title",
          "description",
          "startAt",
          "location",
          "hostId",
          "hostName",
          "status",
          "rsvpSummary",
          "plannedGameIds",
          "createdAt",
          "updatedAt"
        ])
        && data.keys().hasOnly([
          "id",
          "title",
          "description",
          "startAt",
          "location",
          "hostId",
          "hostName",
          "status",
          "rsvpSummary",
          "plannedGameIds",
          "createdAt",
          "updatedAt"
        ])
        && data.id is string
        && data.title is string
        && data.title.size() >= 3
        && data.title.size() <= 80
        && data.description is string
        && data.description.size() <= 1000
        && data.startAt is timestamp
        && data.location is string
        && data.location.size() >= 2
        && data.location.size() <= 120
        && data.hostId is string
        && data.hostId.size() > 0
        && data.hostName is string
        && data.hostName.size() >= 2
        && data.hostName.size() <= 24
        && data.status in ["upcoming", "active", "finished", "cancelled"]
        && hasValidRsvpSummary(data.rsvpSummary)
        && data.plannedGameIds is list
        && data.plannedGameIds.size() <= 50
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidSessionCreate(sessionId) {
      return isAdmin()
        && hasValidSessionShape(request.resource.data)
        && request.resource.data.id == sessionId
        && request.resource.data.rsvpSummary.going == 0
        && request.resource.data.rsvpSummary.maybe == 0
        && request.resource.data.rsvpSummary.notGoing == 0
        && request.resource.data.plannedGameIds.size() == 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isValidAdminSessionUpdate(sessionId) {
      return isAdmin()
        && hasValidSessionShape(request.resource.data)
        && request.resource.data.id == resource.data.id
        && request.resource.data.id == sessionId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
    }

    function hasValidRsvpShape(data, userId) {
      return data.keys().hasAll([
          "userId",
          "userName",
          "status",
          "createdAt",
          "updatedAt"
        ])
        && data.keys().hasOnly([
          "userId",
          "userName",
          "status",
          "createdAt",
          "updatedAt"
        ])
        && data.userId == userId
        && data.userName is string
        && data.userName.size() >= 2
        && data.userName.size() <= 24
        && data.status in ["going", "maybe", "notGoing"]
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function currentRsvpStatus(sessionId, userId) {
      return exists(
        /databases/$(database)/documents/sessions/$(sessionId)/rsvps/$(userId)
      )
        ? get(
            /databases/$(database)/documents/sessions/$(sessionId)/rsvps/$(userId)
          ).data.status
        : "none";
    }

    function statusDelta(oldStatus, newStatus, targetStatus) {
      return (
        (newStatus == targetStatus ? 1 : 0)
        - (oldStatus == targetStatus ? 1 : 0)
      );
    }

    function isValidRsvpTransaction(sessionId, userId) {
      let sessionPath =
        /databases/$(database)/documents/sessions/$(sessionId);

      let rsvpPath =
        /databases/$(database)/documents/sessions/$(sessionId)/rsvps/$(userId);

      let beforeSession = get(sessionPath).data;
      let afterSession = getAfter(sessionPath).data;

      let previousStatus = currentRsvpStatus(sessionId, userId);
      let nextStatus = getAfter(rsvpPath).data.status;

      return hasValidSessionShape(afterSession)
        && afterSession.id == sessionId
        && afterSession.diff(beforeSession).affectedKeys().hasOnly([
          "rsvpSummary",
          "updatedAt"
        ])
        && afterSession.updatedAt == request.time
        && getAfter(rsvpPath).data.userId == userId
        && getAfter(rsvpPath).data.updatedAt == request.time
        && afterSession.rsvpSummary.going
          == beforeSession.rsvpSummary.going
            + statusDelta(previousStatus, nextStatus, "going")
        && afterSession.rsvpSummary.maybe
          == beforeSession.rsvpSummary.maybe
            + statusDelta(previousStatus, nextStatus, "maybe")
        && afterSession.rsvpSummary.notGoing
          == beforeSession.rsvpSummary.notGoing
            + statusDelta(previousStatus, nextStatus, "notGoing");
    }

    function isValidRsvpCreate(sessionId, userId) {
      return hasApprovedEmail()
        && request.auth.uid == userId
        && hasValidRsvpShape(request.resource.data, userId)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && isValidRsvpTransaction(sessionId, userId);
    }

    function isValidRsvpUpdate(sessionId, userId) {
      return hasApprovedEmail()
        && request.auth.uid == userId
        && hasValidRsvpShape(request.resource.data, userId)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && isValidRsvpTransaction(sessionId, userId);
    }

    function hasValidActivityShape(data) {
      return data.keys().hasAll([
          "id",
          "type",
          "actorId",
          "actorName",
          "message",
          "sessionId",
          "createdAt"
        ])
        && data.keys().hasOnly([
          "id",
          "type",
          "actorId",
          "actorName",
          "message",
          "sessionId",
          "createdAt"
        ])
        && data.id is string
        && data.type in [
          "session_created",
          "session_updated",
          "session_rsvp",
          "expense_created",
          "expense_updated",
          "debt_paid",
          "debts_calculated",
          "payment_submitted",
          "debt_resolved",
          "dice_rolled",
          "game_added",
          "member_joined",
          "other"
        ]
        && data.actorId == request.auth.uid
        && data.actorName is string
        && data.actorName.size() >= 2
        && data.actorName.size() <= 24
        && data.message is string
        && data.message.size() >= 1
        && data.message.size() <= 240
        && (data.sessionId == null || data.sessionId is string)
        && data.createdAt is timestamp;
    }

    function hasValidExpenseShareShape(share) {
      return share is map
        && share.keys().hasAll([
          "userId",
          "userName",
          "amountCents"
        ])
        && share.keys().hasOnly([
          "userId",
          "userName",
          "amountCents"
        ])
        && share.userId is string
        && share.userId.size() > 0
        && share.userName is string
        && share.userName.size() >= 2
        && share.userName.size() <= 24
        && share.amountCents is int
        && share.amountCents > 0;
    }

    function hasValidExpenseShape(data) {
      return data.keys().hasAll([
          "id",
          "sessionId",
          "title",
          "category",
          "amountCents",
          "payerId",
          "payerName",
          "participantIds",
          "splitType",
          "shares",
          "note",
          "createdBy",
          "createdAt",
          "updatedAt"
        ])
        && data.keys().hasOnly([
          "id",
          "sessionId",
          "title",
          "category",
          "amountCents",
          "payerId",
          "payerName",
          "participantIds",
          "splitType",
          "shares",
          "note",
          "createdBy",
          "createdAt",
          "updatedAt"
        ])
        && data.id is string
        && data.sessionId is string
        && data.title is string
        && data.title.size() >= 2
        && data.title.size() <= 80
        && data.category in [
          "beer",
          "lemonade",
          "food",
          "snack",
          "cake",
          "pizza",
          "other"
        ]
        && data.amountCents is int
        && data.amountCents > 0
        && data.amountCents <= 10000000
        && data.payerId is string
        && data.payerId.size() > 0
        && data.payerName is string
        && data.payerName.size() >= 2
        && data.payerName.size() <= 24
        && data.participantIds is list
        && data.participantIds.size() >= 1
        && data.participantIds.size() <= 20
        && data.splitType in [
          "single",
          "selected",
          "sessionParticipants",
          "custom"
        ]
        && data.shares is list
        && data.shares.size() >= 1
        && data.shares.size() <= 20
        && data.note is string
        && data.note.size() <= 500
        && data.createdBy is string
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidExpenseCreate(expenseId) {
      return hasApprovedEmail()
        && hasValidExpenseShape(request.resource.data)
        && request.resource.data.id == expenseId
        && request.resource.data.createdBy == request.auth.uid
        && exists(
          /databases/$(database)/documents/sessions/$(request.resource.data.sessionId)
        )
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isValidExpenseUpdate(expenseId) {
      return isAdmin()
        && hasValidExpenseShape(request.resource.data)
        && request.resource.data.id == expenseId
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && exists(
          /databases/$(database)/documents/sessions/$(request.resource.data.sessionId)
        )
        && request.resource.data.updatedAt == request.time;
    }

    function hasValidSettlementShape(data) {
      return data.keys().hasAll([
          "id",
          "sessionId",
          "sessionTitle",
          "sourceExpenseIds",
          "sourceExpenseCount",
          "totalExpenseCents",
          "debtCount",
          "createdBy",
          "createdByName",
          "createdAt"
        ])
        && data.keys().hasOnly([
          "id",
          "sessionId",
          "sessionTitle",
          "sourceExpenseIds",
          "sourceExpenseCount",
          "totalExpenseCents",
          "debtCount",
          "createdBy",
          "createdByName",
          "createdAt"
        ])
        && data.id is string
        && data.sessionId is string
        && data.sessionId.size() > 0
        && data.sessionTitle is string
        && data.sessionTitle.size() >= 3
        && data.sessionTitle.size() <= 80
        && data.sourceExpenseIds is list
        && data.sourceExpenseIds.size() >= 1
        && data.sourceExpenseIds.size() <= 200
        && data.sourceExpenseCount is int
        && data.sourceExpenseCount == data.sourceExpenseIds.size()
        && data.totalExpenseCents is int
        && data.totalExpenseCents >= 0
        && data.totalExpenseCents <= 100000000
        && data.debtCount is int
        && data.debtCount >= 0
        && data.debtCount <= 100
        && data.createdBy == request.auth.uid
        && data.createdByName is string
        && data.createdByName.size() >= 2
        && data.createdByName.size() <= 24
        && data.createdAt is timestamp;
    }

    function isValidSettlementCreate(settlementId) {
      return isAdmin()
        && hasValidSettlementShape(request.resource.data)
        && request.resource.data.id == settlementId
        && request.resource.data.createdAt == request.time;
    }

    function hasOptionalPaymentId(data) {
      return !data.keys().hasAny(["paymentId"])
        || data.paymentId == null
        || data.paymentId is string;
    }

    function paymentIdOrNull(data) {
      return data.keys().hasAny(["paymentId"])
        ? data.paymentId
        : null;
    }

    function hasValidDebtShape(data) {
      return data.keys().hasAll([
          "id",
          "settlementId",
          "sessionId",
          "sessionTitle",
          "fromUserId",
          "fromUserName",
          "toUserId",
          "toUserName",
          "amountCents",
          "status",
          "note",
          "createdBy",
          "createdAt",
          "updatedAt",
          "settledAt",
          "settledById",
          "settledByName"
        ])
        && data.keys().hasOnly([
          "id",
          "settlementId",
          "sessionId",
          "sessionTitle",
          "fromUserId",
          "fromUserName",
          "toUserId",
          "toUserName",
          "amountCents",
          "status",
          "note",
          "createdBy",
          "createdAt",
          "updatedAt",
          "settledAt",
          "settledById",
          "settledByName",
          "paymentId"
        ])
        && data.id is string
        && data.settlementId is string
        && data.settlementId.size() > 0
        && data.sessionId is string
        && data.sessionId.size() > 0
        && data.sessionTitle is string
        && data.sessionTitle.size() >= 3
        && data.sessionTitle.size() <= 80
        && data.fromUserId is string
        && data.fromUserId.size() > 0
        && data.fromUserName is string
        && data.fromUserName.size() >= 2
        && data.fromUserName.size() <= 24
        && data.toUserId is string
        && data.toUserId.size() > 0
        && data.toUserName is string
        && data.toUserName.size() >= 2
        && data.toUserName.size() <= 24
        && data.fromUserId != data.toUserId
        && data.amountCents is int
        && data.amountCents > 0
        && data.amountCents <= 10000000
        && data.status in ["open", "pending", "paid", "forgiven"]
        && data.note is string
        && data.note.size() <= 500
        && data.createdBy is string
        && data.createdBy.size() > 0
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (data.settledAt == null || data.settledAt is timestamp)
        && (data.settledById == null || data.settledById is string)
        && (data.settledByName == null || data.settledByName is string)
        && hasOptionalPaymentId(data);
    }

    function isValidDebtCreate(debtId) {
      return isAdmin()
        && hasValidDebtShape(request.resource.data)
        && request.resource.data.id == debtId
        && request.resource.data.status == "open"
        && request.resource.data.settledAt == null
        && request.resource.data.settledById == null
        && request.resource.data.settledByName == null
        && paymentIdOrNull(request.resource.data) == null
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isValidDebtPaymentSubmission() {
      return hasApprovedEmail()
        && request.auth.uid == resource.data.fromUserId
        && hasValidDebtShape(request.resource.data)
        && resource.data.status == "open"
        && request.resource.data.status == "pending"
        && paymentIdOrNull(resource.data) == null
        && paymentIdOrNull(request.resource.data) is string
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "paymentId",
          "updatedAt"
        ])
        && request.resource.data.updatedAt == request.time
        && request.resource.data.settledAt == null
        && request.resource.data.settledById == null
        && request.resource.data.settledByName == null;
    }

    function hasLinkedPaymentResolution() {
      let paymentId = paymentIdOrNull(resource.data);

      return resource.data.status != "pending"
        || paymentId == null
        || (
          exists(
            /databases/$(database)/documents/payments/$(paymentId)
          )
          && (
            (
              request.resource.data.status == "paid"
              && getAfter(
                /databases/$(database)/documents/payments/$(paymentId)
              ).data.status == "confirmed"
            )
            || (
              request.resource.data.status == "forgiven"
              && getAfter(
                /databases/$(database)/documents/payments/$(paymentId)
              ).data.status == "cancelled"
            )
          )
        );
    }

    function isValidDebtResolution() {
      return isAdmin()
        && hasValidDebtShape(request.resource.data)
        && request.resource.data.id == resource.data.id
        && request.resource.data.settlementId == resource.data.settlementId
        && request.resource.data.sessionId == resource.data.sessionId
        && request.resource.data.sessionTitle == resource.data.sessionTitle
        && request.resource.data.fromUserId == resource.data.fromUserId
        && request.resource.data.fromUserName == resource.data.fromUserName
        && request.resource.data.toUserId == resource.data.toUserId
        && request.resource.data.toUserName == resource.data.toUserName
        && request.resource.data.amountCents == resource.data.amountCents
        && request.resource.data.note == resource.data.note
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && paymentIdOrNull(request.resource.data)
          == paymentIdOrNull(resource.data)
        && resource.data.status in ["open", "pending"]
        && request.resource.data.status in ["paid", "forgiven"]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "updatedAt",
          "settledAt",
          "settledById",
          "settledByName"
        ])
        && request.resource.data.updatedAt == request.time
        && request.resource.data.settledAt == request.time
        && request.resource.data.settledById == request.auth.uid
        && request.resource.data.settledByName is string
        && request.resource.data.settledByName.size() >= 2
        && request.resource.data.settledByName.size() <= 24
        && hasLinkedPaymentResolution();
    }

    function hasValidPaymentShape(data) {
      return data.keys().hasAll([
          "id",
          "debtId",
          "sessionId",
          "sessionTitle",
          "fromUserId",
          "fromUserName",
          "toUserId",
          "toUserName",
          "amountCents",
          "method",
          "status",
          "recipientAccount",
          "recipientName",
          "variableSymbol",
          "message",
          "submittedById",
          "submittedByName",
          "submittedAt",
          "reviewedAt",
          "reviewedById",
          "reviewedByName"
        ])
        && data.keys().hasOnly([
          "id",
          "debtId",
          "sessionId",
          "sessionTitle",
          "fromUserId",
          "fromUserName",
          "toUserId",
          "toUserName",
          "amountCents",
          "method",
          "status",
          "recipientAccount",
          "recipientName",
          "variableSymbol",
          "message",
          "submittedById",
          "submittedByName",
          "submittedAt",
          "reviewedAt",
          "reviewedById",
          "reviewedByName"
        ])
        && data.id is string
        && data.debtId is string
        && data.debtId.size() > 0
        && data.sessionId is string
        && data.sessionId.size() > 0
        && data.sessionTitle is string
        && data.sessionTitle.size() >= 3
        && data.sessionTitle.size() <= 80
        && data.fromUserId is string
        && data.fromUserName is string
        && data.toUserId is string
        && data.toUserName is string
        && data.amountCents is int
        && data.amountCents > 0
        && data.method == "qr_payment"
        && data.status in ["submitted", "confirmed", "cancelled"]
        && data.recipientAccount is string
        && data.recipientAccount.matches("^CZ[0-9]{22}$")
        && data.recipientName is string
        && data.recipientName.size() >= 2
        && data.recipientName.size() <= 120
        && (
          data.variableSymbol == null
          || (
            data.variableSymbol is string
            && data.variableSymbol.matches("^[0-9]{1,10}$")
          )
        )
        && data.message is string
        && data.message.size() >= 1
        && data.message.size() <= 60
        && data.submittedById is string
        && data.submittedByName is string
        && data.submittedAt is timestamp
        && (data.reviewedAt == null || data.reviewedAt is timestamp)
        && (data.reviewedById == null || data.reviewedById is string)
        && (data.reviewedByName == null || data.reviewedByName is string);
    }

    function isValidPaymentSubmission(paymentId) {
      let debtPath =
        /databases/$(database)/documents/debts/$(request.resource.data.debtId);

      let afterDebt = getAfter(debtPath).data;

      return hasApprovedEmail()
        && hasValidPaymentShape(request.resource.data)
        && request.resource.data.id == paymentId
        && request.resource.data.status == "submitted"
        && request.resource.data.submittedById == request.auth.uid
        && request.resource.data.submittedById
          == request.resource.data.fromUserId
        && request.resource.data.submittedAt == request.time
        && request.resource.data.reviewedAt == null
        && request.resource.data.reviewedById == null
        && request.resource.data.reviewedByName == null
        && exists(debtPath)
        && afterDebt.status == "pending"
        && paymentIdOrNull(afterDebt) == paymentId
        && afterDebt.id == request.resource.data.debtId
        && afterDebt.sessionId == request.resource.data.sessionId
        && afterDebt.sessionTitle == request.resource.data.sessionTitle
        && afterDebt.fromUserId == request.resource.data.fromUserId
        && afterDebt.fromUserName == request.resource.data.fromUserName
        && afterDebt.toUserId == request.resource.data.toUserId
        && afterDebt.toUserName == request.resource.data.toUserName
        && afterDebt.amountCents == request.resource.data.amountCents;
    }

    function isValidPaymentReview() {
      let debtPath =
        /databases/$(database)/documents/debts/$(resource.data.debtId);

      let afterDebt = getAfter(debtPath).data;

      return isAdmin()
        && hasValidPaymentShape(request.resource.data)
        && request.resource.data.id == resource.data.id
        && request.resource.data.debtId == resource.data.debtId
        && request.resource.data.sessionId == resource.data.sessionId
        && request.resource.data.sessionTitle == resource.data.sessionTitle
        && request.resource.data.fromUserId == resource.data.fromUserId
        && request.resource.data.fromUserName == resource.data.fromUserName
        && request.resource.data.toUserId == resource.data.toUserId
        && request.resource.data.toUserName == resource.data.toUserName
        && request.resource.data.amountCents == resource.data.amountCents
        && request.resource.data.method == resource.data.method
        && request.resource.data.recipientAccount
          == resource.data.recipientAccount
        && request.resource.data.recipientName
          == resource.data.recipientName
        && request.resource.data.variableSymbol
          == resource.data.variableSymbol
        && request.resource.data.message == resource.data.message
        && request.resource.data.submittedById
          == resource.data.submittedById
        && request.resource.data.submittedByName
          == resource.data.submittedByName
        && request.resource.data.submittedAt
          == resource.data.submittedAt
        && resource.data.status == "submitted"
        && request.resource.data.status in ["confirmed", "cancelled"]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "reviewedAt",
          "reviewedById",
          "reviewedByName"
        ])
        && request.resource.data.reviewedAt == request.time
        && request.resource.data.reviewedById == request.auth.uid
        && request.resource.data.reviewedByName is string
        && request.resource.data.reviewedByName.size() >= 2
        && request.resource.data.reviewedByName.size() <= 24
        && exists(debtPath)
        && (
          (
            request.resource.data.status == "confirmed"
            && afterDebt.status == "paid"
          )
          || (
            request.resource.data.status == "cancelled"
            && afterDebt.status == "forgiven"
          )
        );
    }

    function hasValidAppSettingsShape(data) {
      return data.keys().hasAll([
          "id",
          "partyNotice",
          "paymentRecipientAccount",
          "paymentRecipientName",
          "defaultPaymentMessage",
          "defaultPaymentVariableSymbol",
          "updatedAt"
        ])
        && data.keys().hasOnly([
          "id",
          "partyNotice",
          "paymentRecipientAccount",
          "paymentRecipientName",
          "defaultPaymentMessage",
          "defaultPaymentVariableSymbol",
          "updatedAt"
        ])
        && data.id == "main"
        && (
          data.partyNotice == null
          || (
            data.partyNotice is string
            && data.partyNotice.size() <= 300
          )
        )
        && (
          data.paymentRecipientAccount == null
          || (
            data.paymentRecipientAccount is string
            && data.paymentRecipientAccount.matches("^CZ[0-9]{22}$")
          )
        )
        && (
          data.paymentRecipientName == null
          || (
            data.paymentRecipientName is string
            && data.paymentRecipientName.size() >= 2
            && data.paymentRecipientName.size() <= 120
          )
        )
        && (
          data.defaultPaymentMessage == null
          || (
            data.defaultPaymentMessage is string
            && data.defaultPaymentMessage.size() <= 60
          )
        )
        && (
          data.defaultPaymentVariableSymbol == null
          || (
            data.defaultPaymentVariableSymbol is string
            && data.defaultPaymentVariableSymbol.matches("^[0-9]{1,10}$")
          )
        )
        && data.updatedAt is timestamp;
    }

    function isValidAppSettingsWrite(settingsId) {
      return isAdmin()
        && settingsId == "main"
        && hasValidAppSettingsShape(request.resource.data)
        && request.resource.data.updatedAt == request.time;
    }

    function hasValidDiceRollShape(data) {
  return data.keys().hasAll([
      "id",
      "rollerId",
      "rollerName",
      "sessionId",
      "sessionTitle",
      "dieSides",
      "quantity",
      "modifier",
      "rollMode",
      "individualRolls",
      "keptRoll",
      "total",
      "isCriticalHit",
      "isCriticalFail",
      "createdAt"
    ])
    && data.keys().hasOnly([
      "id",
      "rollerId",
      "rollerName",
      "sessionId",
      "sessionTitle",
      "dieSides",
      "quantity",
      "modifier",
      "rollMode",
      "individualRolls",
      "keptRoll",
      "total",
      "isCriticalHit",
      "isCriticalFail",
      "createdAt"
    ])
    && data.id is string
    && data.rollerId == request.auth.uid
    && data.rollerName is string
    && data.rollerName.size() >= 2
    && data.rollerName.size() <= 24
    && (
      data.sessionId == null
      || (
        data.sessionId is string
        && data.sessionId.size() > 0
      )
    )
    && (
      data.sessionTitle == null
      || (
        data.sessionTitle is string
        && data.sessionTitle.size() >= 3
        && data.sessionTitle.size() <= 80
      )
    )
    && data.dieSides in [4, 6, 8, 10, 12, 20, 100]
    && data.quantity is int
    && data.quantity >= 1
    && data.quantity <= 20
    && data.modifier is int
    && data.modifier >= -100
    && data.modifier <= 100
    && data.rollMode in [
      "standard",
      "advantage",
      "disadvantage"
    ]
    && data.individualRolls is list
    && data.individualRolls.size() >= 1
    && data.individualRolls.size() <= 20
    && (
      data.keptRoll == null
      || data.keptRoll is int
    )
    && data.total is int
    && data.isCriticalHit is bool
    && data.isCriticalFail is bool
    && data.createdAt is timestamp
    && (
      (
        data.rollMode == "standard"
        && data.individualRolls.size() == data.quantity
        && data.keptRoll == null
      )
      || (
        data.rollMode in ["advantage", "disadvantage"]
        && data.dieSides == 20
        && data.quantity == 1
        && data.individualRolls.size() == 2
        && data.keptRoll is int
      )
    );
}

function isValidDiceRollCreate(rollId) {
  return hasApprovedEmail()
    && hasValidDiceRollShape(request.resource.data)
    && request.resource.data.id == rollId
    && request.resource.data.createdAt == request.time;
}

function hasValidGameShape(data) {
  return data.keys().hasAll([
      "id",
      "title",
      "category",
      "minPlayers",
      "maxPlayers",
      "playTimeMinutes",
      "complexity",
      "ownership",
      "ownerName",
      "notes",
      "isAvailable",
      "addedById",
      "addedByName",
      "createdAt",
      "updatedAt"
    ])
    && data.keys().hasOnly([
      "id",
      "title",
      "category",
      "minPlayers",
      "maxPlayers",
      "playTimeMinutes",
      "complexity",
      "ownership",
      "ownerName",
      "notes",
      "isAvailable",
      "addedById",
      "addedByName",
      "createdAt",
      "updatedAt"
    ])
    && data.id is string
    && data.title is string
    && data.title.size() >= 2
    && data.title.size() <= 100
    && data.category in [
      "boardgame",
      "cardgame",
      "rpg",
      "party",
      "miniatures",
      "other"
    ]
    && data.minPlayers is int
    && data.minPlayers >= 1
    && data.minPlayers <= 20
    && data.maxPlayers is int
    && data.maxPlayers >= data.minPlayers
    && data.maxPlayers <= 20
    && data.playTimeMinutes is int
    && data.playTimeMinutes >= 5
    && data.playTimeMinutes <= 600
    && data.complexity is int
    && data.complexity >= 1
    && data.complexity <= 5
    && data.ownership in [
      "party",
      "member",
      "borrowed"
    ]
    && data.ownerName is string
    && data.ownerName.size() >= 2
    && data.ownerName.size() <= 80
    && data.notes is string
    && data.notes.size() <= 1000
    && data.isAvailable is bool
    && data.addedById is string
    && data.addedById.size() > 0
    && data.addedByName is string
    && data.addedByName.size() >= 2
    && data.addedByName.size() <= 24
    && data.createdAt is timestamp
    && data.updatedAt is timestamp;
}

function isValidGameCreate(gameId) {
  return isAdmin()
    && hasValidGameShape(request.resource.data)
    && request.resource.data.id == gameId
    && request.resource.data.addedById == request.auth.uid
    && request.resource.data.createdAt == request.time
    && request.resource.data.updatedAt == request.time;
}

function isValidGameUpdate(gameId) {
  return isAdmin()
    && hasValidGameShape(request.resource.data)
    && request.resource.data.id == gameId
    && request.resource.data.id == resource.data.id
    && request.resource.data.addedById == resource.data.addedById
    && request.resource.data.addedByName == resource.data.addedByName
    && request.resource.data.createdAt == resource.data.createdAt
    && request.resource.data.updatedAt == request.time;
}

function hasValidNotificationStateShape(data) {
  return data.keys().hasAll([
      "id",
      "lastSeenAt",
      "updatedAt"
    ])
    && data.keys().hasOnly([
      "id",
      "lastSeenAt",
      "updatedAt"
    ])
    && data.id == "main"
    && data.lastSeenAt is timestamp
    && data.updatedAt is timestamp;
}

function isValidOwnNotificationStateWrite(userId, stateId) {
  return hasApprovedEmail()
    && request.auth.uid == userId
    && stateId == "main"
    && hasValidNotificationStateShape(request.resource.data)
    && request.resource.data.lastSeenAt == request.time
    && request.resource.data.updatedAt == request.time
    && (
      !exists(
        /databases/$(database)/documents/users/$(userId)/notificationState/$(stateId)
      )
      || request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          "lastSeenAt",
          "updatedAt"
        ])
    );
}

function hasValidPendingJoinRequestShape(data, requestId) {
  return data.keys().hasAll([
      "id",
      "email",
      "displayName",
      "status",
      "requestedAt",
      "updatedAt",
      "reviewedAt",
      "reviewedById",
      "reviewedByName"
    ])
    && data.keys().hasOnly([
      "id",
      "email",
      "displayName",
      "status",
      "requestedAt",
      "updatedAt",
      "reviewedAt",
      "reviewedById",
      "reviewedByName"
    ])
    && data.id is string
    && data.id == requestId
    && data.email is string
    && data.email.size() >= 3
    && data.email.size() <= 254
    && request.auth.token.email is string
    && data.email == request.auth.token.email
    && data.displayName is string
    && data.displayName.size() >= 2
    && data.displayName.size() <= 24
    && data.status == "pending"
    && data.requestedAt is timestamp
    && data.requestedAt == request.time
    && data.updatedAt is timestamp
    && data.updatedAt == request.time
    && data.reviewedAt == null
    && data.reviewedById == null
    && data.reviewedByName == null;
}

function isValidPendingJoinRequestCreate(requestId) {
  return isSignedIn()
    && request.auth.uid == requestId
    && hasValidPendingJoinRequestShape(
      request.resource.data,
      requestId
    );
}

match /joinRequests/{requestId} {
  allow get: if isAdmin()
    || (
      isSignedIn()
      && request.auth.uid == requestId
    );

  allow list: if isAdmin();

  allow create: if isValidPendingJoinRequestCreate(
    requestId
  );

  allow update, delete: if false;
}

    match /users/{userId} {
  allow get, list: if hasApprovedEmail();

  allow create: if isSignedIn()
    && request.auth.uid == userId
    && isValidInitialProfile(userId);

  allow update: if (
    request.auth.uid == userId
    && isValidOwnProfileUpdate(userId)
  ) || isValidAdminRoleUpdate(userId);

  allow delete: if isAdmin();

  match /notificationState/{stateId} {
  allow get: if hasApprovedEmail()
    && request.auth.uid == userId;

  allow create, update: if isValidOwnNotificationStateWrite(
    userId,
    stateId
  );

  allow list, delete: if false;
}
}

    match /sessions/{sessionId} {
      allow get, list: if hasApprovedEmail();

      allow create: if isValidSessionCreate(sessionId);

      allow update: if isValidAdminSessionUpdate(sessionId)
        || (
          hasApprovedEmail()
          && isValidRsvpTransaction(sessionId, request.auth.uid)
        );

      allow delete: if isAdmin();

      match /rsvps/{userId} {
        allow get, list: if hasApprovedEmail();

        allow create: if isValidRsvpCreate(sessionId, userId);

        allow update: if isValidRsvpUpdate(sessionId, userId);

        allow delete: if false;
      }
    }

    match /games/{gameId} {
  allow get, list: if hasApprovedEmail();

  allow create: if isValidGameCreate(gameId);

  allow update: if isValidGameUpdate(gameId);

  allow delete: if false;
}

    match /expenses/{expenseId} {
      allow get, list: if hasApprovedEmail();

      allow create: if isValidExpenseCreate(expenseId);

      allow update: if isValidExpenseUpdate(expenseId);

      allow delete: if isAdmin();
    }

    match /settlements/{settlementId} {
      allow get, list: if hasApprovedEmail();

      allow create: if isValidSettlementCreate(settlementId);

      allow update, delete: if false;
    }

    match /debts/{debtId} {
      allow get, list: if hasApprovedEmail();

      allow create: if isValidDebtCreate(debtId);

      allow update: if isValidDebtPaymentSubmission()
        || isValidDebtResolution();

      allow delete: if false;
    }

    match /diceRolls/{rollId} {
  allow get, list: if hasApprovedEmail();

  allow create: if isValidDiceRollCreate(rollId);

  allow update, delete: if false;
}

    match /payments/{paymentId} {
      allow get, list: if hasApprovedEmail();

      allow create: if isValidPaymentSubmission(paymentId);

      allow update: if isValidPaymentReview();

      allow delete: if false;
    }

    match /activityLog/{activityId} {
      allow get, list: if hasApprovedEmail();

      allow create: if hasApprovedEmail()
        && hasValidActivityShape(request.resource.data)
        && request.resource.data.id == activityId
        && request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    match /appSettings/{settingsId} {
      allow get: if hasApprovedEmail();

      allow create, update: if isValidAppSettingsWrite(settingsId);

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}